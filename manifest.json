{
  "manifest_version": 3,
  "name": "Macros Repeater",
  "description": "Minimal dev skeleton for macros repeater extension.",
  "version": "0.0.1",
  "action": {
    "default_title": "Macros Repeater",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon-16.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "permissions": [
    "storage"
  ],
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}
